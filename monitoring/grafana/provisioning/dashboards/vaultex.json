{
  "title": "Vaultex — Everything. Elevated.",
  "uid": "vaultex-main",
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Services Status",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 4 },
      "targets": [
        {
          "expr": "up{job=~\"user-service|seller-service|cart-service|payment-service|product-service|order-service\"}",
          "legendFormat": "{{job}}"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ]
        }
      }
    },
    {
      "id": 2,
      "title": "CPU Usage %",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU %"
        }
      ]
    },
    {
      "id": 3,
      "title": "Memory Usage %",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "Memory %"
        }
      ]
    },
    {
      "id": 4,
      "title": "Container CPU Usage",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"vaultex.*\"}[5m]) * 100",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Container Memory Usage (MB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\"vaultex.*\"} / 1024 / 1024",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Network I/O",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "rate(container_network_receive_bytes_total{name=~\"vaultex.*\"}[5m])",
          "legendFormat": "{{name}} RX"
        },
        {
          "expr": "rate(container_network_transmit_bytes_total{name=~\"vaultex.*\"}[5m])",
          "legendFormat": "{{name}} TX"
        }
      ]
    }
  ],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser"
}
